# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6356
REDIS_PASSWORD=CHANGE_ME

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5317
RABBITMQ_UI_PORT=15317
RABBITMQ_DEFAULT_USER=rabbit
RABBITMQ_DEFAULT_PASS=CHANGE_ME
RABBITMQ_LOGS=
RABBITMQ_LOG_BASE=/var/log/rabbitmq

# 可选：远程浏览器配置（启用 browser_req 时需要）
BROWSER_SERVERS=
BROWSER_PORTS=
BROWSER_NUM=0
BROWSER_TOKEN=

# 请求配置（默认关闭证书校验，抓取场景更兼容）
REQ_VERIFY_SSL=False

# Github OAUTH 配置
GITHUB_CLIENT_ID=
GITHUB_SECRET=

# 邮件发送配置
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=465
MAIL_USER=
MAIL_PASSWORD=

MAIL_FROM=SEC.CAFE 安全咖啡
# 可选，多个地址使用英文逗号分隔
MAIL_BCC=

# 翻译配置（至少配置一个）
TRANSLATE_TENCENT_ID=
TRANSLATE_TENCENT_KEY=
TRANSLATE_BAIDU_ID=
TRANSLATE_BAIDU_KEY=
TRANSLATE_XIAONIU_KEY=

# Sentry 配置
SENTRY_API_DNS=
SENTRY_BACKEND_DNS=
SENTRY_CRAWLER_DNS=

# OPENAPI KEY，用于大模型做漏洞相似性判断
OPENAPI_KEY=
# 可选，兼容代理/三方网关，如 https://api.openai.com/v1
OPENAPI_BASE_URL=
# 可选，默认 gpt-4o-mini
OPENAPI_MODEL=gpt-4o-mini
